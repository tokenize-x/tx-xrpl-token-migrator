groups:
  - name: Bridge Monitoring
    rules:
    - alert: InstanceDown
      # Condition for alerting
      expr: time() - timestamp(coreum_contract_balance) > 60
      for: 1m
      annotations:
        title: 'Instance {{ $labels.instance }} does not report updated balance for 1 minute, it might be down!'
        description: '{{ $labels.job }} on {{ $labels.instance }} has not been updating contract balance for more than 1 minute, it might be down'
      labels:
        severity: critical

    - alert: ContractLowBalance
      expr: coreum_contract_balance{job="bridge"} < 50000000000
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Contract balance is less than 50000'

    - alert: SenderLowBalance
      expr: coreum_sender_balance{job="bridge"} < 10000000
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Sender balance is less than 10'

    - alert: BridgeErrorsRate
      expr: rate(errors_total{job="bridge"}[5m]) * 5 * 60 > 10
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Bridge errors count for the last 5min > 10'

    - alert: BridgePendingUnapprovedRate
      expr: rate(coreum_pending_unapproved_transactions_count{job="bridge"}[5m]) * 5 * 60 > 3
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Bridge pending unapproved transactions rate for the last 5min > 3'

    - alert: BridgePendingApprovedRate
      expr: rate(coreum_pending_approved_transactions_count{job="bridge"}[1m]) * 5 * 60 > 0
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Bridge pending approved transactions rate for the last 1min > 0'
