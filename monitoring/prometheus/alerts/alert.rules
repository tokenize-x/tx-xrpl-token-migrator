groups:
  - name: Bridge Monitoring
    rules:
    - alert: InstanceDown
      # Condition for alerting
      expr: time() - push_time_seconds{instance !~ ""} > 60
      for: 1m
      annotations:
        title: 'Instance {{ $labels.instance }} does not push metrics for 1 minute, it might be down!'
        description: '{{ $labels.job }} on {{ $labels.instance }} has not been updating metrics more than 1 minute, it might be down'
      labels:
        severity: critical

    - alert: ContractLowBalance
      expr: tx_contract_balance{job="bridge"} < 50000000000
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Contract balance is less than 50 000, reported by `{{ $labels.instance }}`, actual value `{{ $value }}`'

    - alert: SenderLowBalance
      expr: tx_sender_balance{job="bridge"} < 10000000
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Sender balance is less than 10, reported by `{{ $labels.instance }}`, actual value `{{ $value }}'

    - alert: BridgeErrorsRateIncreased
      expr: rate(errors_total{job="bridge"}[5m]) * 5 * 60 > 10
      for: 30s
      labels:
        severity: major
      annotations:
        description: 'Bridge errors count for the last 5min > 10'

    - alert: BridgePendingUnapprovedMaxReached
      expr: tx_pending_unapproved_transactions_count{job="bridge"} > 3
      for: 5m
      labels:
        severity: major
      annotations:
        description: 'Bridge pending unapproved transactions count for the last 5min > 3'

    - alert: BridgePendingApprovedTransactionFound
      expr: tx_pending_approved_transactions_count{job="bridge"} > 0
      for: 1m
      labels:
        severity: major
      annotations:
        description: 'Bridge pending approved transactions count for the last 1min > 0'
